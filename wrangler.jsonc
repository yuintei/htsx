{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "htsx",
  "main": "./dist/index.js",
  "compatibility_date": "2025-08-29",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
}
